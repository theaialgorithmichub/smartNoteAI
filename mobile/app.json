{
  "expo": {
    "name": "SmartNote AI",
    "slug": "smartnote-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartnoteai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.smartnoteai.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "smartnote",
              "host": "share"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SmartNote AI to access your photos for notebook covers."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SmartNote AI to access your camera."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow SmartNote AI to access your microphone for voice transcription."
        }
      ]
    ],
    "scheme": "smartnote",
    "extra": {
      "clerkPublishableKey": "your_clerk_publishable_key_here"
    }
  }
}
