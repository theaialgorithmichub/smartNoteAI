# ============================================================
# SmartNote AI Mobile App — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Clerk Authentication ────────────────────────────────────
# 1. Go to https://dashboard.clerk.com
# 2. Create a new app (or use your existing SmartNote AI app)
# 3. Go to API Keys → copy the "Publishable Key"
#
# IMPORTANT: Use the SAME Clerk app as your web backend.
# Both must share the same Clerk app so user accounts are synced.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── Backend API URL ─────────────────────────────────────────
# This is the URL of your SmartNote AI web backend.
#
# Option A — If your web app is deployed online:
#   EXPO_PUBLIC_API_URL=https://your-smartnote-domain.com
#
# Option B — If your web backend runs on your computer (same WiFi):
#   Find your computer's local IP:
#     Windows: run ipconfig → IPv4 Address (e.g. 192.168.1.10)
#     Mac/Linux: run ifconfig → inet under en0
#   Then use:
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
#   NOTE: Do NOT use localhost or 127.0.0.1 — your phone can't reach those.
#         Android emulator uses 10.0.2.2 instead of localhost.
EXPO_PUBLIC_API_URL=https://your-smartnote-domain.com
